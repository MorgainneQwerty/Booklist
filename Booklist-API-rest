# 1. Importar o FastAPI e a classe BaseModel do Pydantic (para validação de dados)
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
from typing import List

# 2. Inicializar a aplicação FastAPI
app = FastAPI(title="API de Catálogo de Livros")

# 3. Definir o modelo de dados que a API vai aceitar (validação automática)
class Livro(BaseModel):
    id: int
    titulo: str
    autor: str

# Modelo específico para quando formos criar um livro (não precisamos enviar o ID)
class LivroCreate(BaseModel):
    titulo: str
    autor: str

# 4. Criar a nossa "base de dados" simulada (uma lista de dicionários)
livros_db = [
    {"id": 1, "titulo": "O Senhor dos Anéis", "autor": "J.R.R. Tolkien"},
    {"id": 2, "titulo": "O Alquimista", "autor": "Paulo Coelho"}
]

# 5. Rota GET: Retorna a lista de todos os livros
@app.get("/livros", response_model=List[Livro])
def listar_livros():
    # O FastAPI transforma automaticamente esta lista Python em formato JSON
    return livros_db

# 6. Rota POST: Recebe um novo livro e adiciona à lista
@app.post("/livros", response_model=Livro, status_code=201)
def criar_livro(livro: LivroCreate):
    # Gerar um ID incremental simples
    novo_id = len(livros_db) + 1
    
    # Criar o dicionário do novo livro com os dados recebidos
    novo_livro = {
        "id": novo_id,
        "titulo": livro.titulo,
        "autor": livro.autor
    }
    
    # Adicionar à nossa lista
    livros_db.append(novo_livro)
    
    # Retornar o livro criado (Status 201 Created automático)
    return novo_livro
